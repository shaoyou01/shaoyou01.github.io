---
import { Icon } from "astro-icon/components";
import { homepage } from "../data/homepage";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const sectionTitleClass =
	"flex items-center gap-3 text-2xl font-bold text-90 mb-5";
const iconBoxClass =
	"h-10 w-10 rounded-xl bg-(--enter-btn-bg) flex items-center justify-center text-(--primary)";
---

<MainGridLayout title="homepage" description={homepage.summary}>
	<div class="flex flex-col gap-4">
		<section class="card-base rounded-(--radius-large) p-6 md:p-8 onload-animation">
			<div class="flex flex-col gap-6">
				<div>
					<div class="flex flex-wrap items-center gap-3 mb-4">
						<span class="btn-regular rounded-lg h-8 px-3 text-sm font-bold">
							{homepage.role}
						</span>
						<span class="text-50 text-sm">{homepage.location}</span>
					</div>
					<h1 class="text-4xl md:text-5xl font-bold text-90 mb-3">
						{homepage.name}
					</h1>
					<div class="h-1.5 w-14 rounded-full bg-(--primary) mb-5"></div>
					<p class="text-75 text-lg leading-8 max-w-3xl">
						{homepage.summary}
					</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-3">
					<div class="rounded-xl bg-(--card-bg-hover) p-4">
						<div class="text-50 text-sm mb-1">Affiliation</div>
						<div class="text-90 font-bold">{homepage.affiliation}</div>
					</div>
					<div class="rounded-xl bg-(--card-bg-hover) p-4">
						<div class="text-50 text-sm mb-1">Graduation</div>
						<div class="text-90 font-bold">{homepage.graduation}</div>
					</div>
				</div>

				<div class="flex flex-wrap gap-2">
					{homepage.interests.map((interest) => (
						<span class="btn-regular h-8 rounded-lg px-3 text-sm">
							# {interest}
						</span>
					))}
				</div>
			</div>
		</section>

		<section class="card-base rounded-(--radius-large) p-6 md:p-8 onload-animation">
			<h2 class={sectionTitleClass}>
				<span class={iconBoxClass}>
					<Icon name="material-symbols:newspaper-rounded" class="text-2xl" />
				</span>
				Recent News
			</h2>
			<div class="flex flex-col gap-3">
				{homepage.news.map((item) => (
					<div class="flex gap-4 rounded-xl bg-(--card-bg-hover) p-4">
						<div class="text-(--primary) font-bold shrink-0">{item.date}</div>
						<div class="text-75 leading-7">{item.text}</div>
					</div>
				))}
			</div>
		</section>

		<section class="card-base rounded-(--radius-large) p-6 md:p-8 onload-animation">
			<h2 class={sectionTitleClass}>
				<span class={iconBoxClass}>
					<Icon name="material-symbols:psychology-rounded" class="text-2xl" />
				</span>
				Research
			</h2>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-3">
				{homepage.research.map((item) => (
					<div class="rounded-xl bg-(--card-bg-hover) p-4">
						<div class="text-90 font-bold mb-2">{item.title}</div>
						<p class="text-75 text-sm leading-6">{item.description}</p>
					</div>
				))}
			</div>
		</section>

		<section class="card-base rounded-(--radius-large) p-6 md:p-8 onload-animation">
			<h2 class={sectionTitleClass}>
				<span class={iconBoxClass}>
					<Icon name="material-symbols:menu-book-rounded" class="text-2xl" />
				</span>
				Publications
			</h2>
			<div class="flex flex-col gap-4">
				{homepage.publications.map((paper) => (
					<article class="rounded-xl bg-(--card-bg-hover) p-4">
						<div class="flex flex-wrap gap-2 items-center mb-2">
							<span class="btn-regular h-7 rounded-lg px-2 text-xs font-bold">
								{paper.venue}
							</span>
						</div>
						<h3 class="text-xl font-bold text-90 mb-2">{paper.title}</h3>
						<p class="text-50 text-sm leading-6 mb-3">{paper.authors}</p>
						<p class="text-75 leading-7">{paper.description}</p>
					</article>
				))}
			</div>
		</section>

		<section class="card-base rounded-(--radius-large) p-6 md:p-8 onload-animation">
			<h2 class={sectionTitleClass}>
				<span class={iconBoxClass}>
					<Icon name="material-symbols:school-rounded" class="text-2xl" />
				</span>
				Education & Awards
			</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
				<div class="rounded-xl bg-(--card-bg-hover) p-4">
					{homepage.education.map((edu) => (
						<div>
							<div class="text-90 font-bold">{edu.school}</div>
							<div class="text-75 mt-1">{edu.program}</div>
							<div class="text-50 text-sm mt-1">{edu.period}</div>
							<div class="text-(--primary) text-sm font-bold mt-3">{edu.detail}</div>
						</div>
					))}
				</div>
				<div class="rounded-xl bg-(--card-bg-hover) p-4">
					<ul class="flex flex-col gap-3">
						{homepage.awards.map((award) => (
							<li class="text-75 text-sm leading-6 flex gap-2">
								<span class="text-(--primary) mt-0.5">●</span>
								<span>{award}</span>
							</li>
						))}
					</ul>
				</div>
			</div>
		</section>
	</div>
</MainGridLayout>
