---
import { getSortedPosts } from "../../utils/content-utils";
import { getPostUrl } from "../../utils/url-utils";
import SimpleLayout from "../../layouts/SimpleLayout.astro";

const posts = await getSortedPosts();
---

<SimpleLayout title="blogs" description="Blog posts by Chuan Xiao.">
	<section class="blog-header">
		<p class="eyebrow">Writing and notes</p>
		<h1>blogs</h1>
		<p class="hero-summary">
			Notes on programming, code agents, security, research practice, and
			the tools I use while learning.
		</p>
	</section>
	<ul class="post-list">
		{posts.map((post) => (
			<li>
				<a class="post-link" href={getPostUrl(post)}>
					<time class="date" datetime={post.data.published.toISOString()}>
						{post.data.published.toLocaleDateString("en-US", {
							year: "numeric",
							month: "short",
							day: "2-digit",
						})}
					</time>
					<div>
						<h2>{post.data.title}</h2>
						<p>{post.data.description}</p>
						<div class="tags">
							{post.data.tags.map((tag) => <span>#{tag} </span>)}
						</div>
					</div>
				</a>
			</li>
		))}
	</ul>
</SimpleLayout>
